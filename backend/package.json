{
  "name": "agile-project-management-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Agile Project Management Tool",
  "main": "src/index.js",
  "type": "module",
 "scripts": {
  "dev": "node --watch src/index.js",
  "start": "prisma migrate deploy && node src/index.js",
  "build": "prisma generate && prisma migrate deploy",
  "db:migrate": "prisma migrate dev",
  "db:reset": "prisma migrate reset",
  "db:seed": "node src/utils/seed.js",
  "db:studio": "prisma studio",
  "lint": "eslint src",
  "test": "jest",
  "format": "prettier --write \"src/**/*.js\""
},
  "keywords": [
    "agile",
    "project-management",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^8.5.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "^5.8.0"
  }
}
